# Postgres (docker-compose default)
DATABASE_URL=postgres://dlmm:dlmm@localhost:5432/dlmm

# Helius. RPC_URL/WS_URL may be any Solana RPC, but Helius is assumed.
HELIUS_API_KEY=
# Optional explicit overrides; default is derived from HELIUS_API_KEY:
#   https://mainnet.helius-rpc.com/?api-key=$HELIUS_API_KEY
# RPC_URL=
# WS_URL=

# Jupiter Price API v3 (optional; keyless works at 0.5 req/s)
JUPITER_API_KEY=

# Ingestion tuning (defaults shown)
# RPC max requests per second for tx fetching/backfill
# RPC_RPS=8
# BIN_SNAPSHOT_INTERVAL_MS=45000
# METRICS_INTERVAL_MS=60000
# DISCOVERY_INTERVAL_MS=300000
# WATCHLIST_SIZE=15
